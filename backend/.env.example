# Supabase (leave blank to run without Supabase — auth, cache, logging disabled)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Auth — set to true to enforce JWT validation on all endpoints
REQUIRE_AUTH=false

# yt-dlp — set to your browser name so yt-dlp can extract YouTube cookies.
# Supported: chrome, firefox, edge, opera, brave, vivaldi, safari
# Leave blank to use music.youtube.com without cookies (works for most tracks).
YT_COOKIE_BROWSER=
